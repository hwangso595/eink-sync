{
  "name": "eink-sync",
  "version": "0.3.0",
  "description": "ReMarkable-to-Obsidian bridge: local-first highlight extraction without cloud dependency",
  "main": "main.js",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "lint": "eslint src/ --ext .ts",
    "install-plugin": "node scripts/install-plugin.mjs",
    "release": "node scripts/release.mjs"
  },
  "keywords": [
    "obsidian",
    "remarkable",
    "pdf",
    "highlights",
    "sync"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/ssh2": "^1.15.0",
    "esbuild": "^0.20.0",
    "jest": "^29.7.0",
    "obsidian": "^1.5.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ssh2": "^1.15.0"
  }
}
